# A2A-World Environment Configuration

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://a2a:a2a_dev_password@localhost:5432/a2a_world
POSTGRES_USER=a2a
POSTGRES_PASSWORD=a2a_dev_password
POSTGRES_DB=a2a_world

# ============================================================================
# IPFS / Pinata API Configuration (Artifact Storage)
# ============================================================================
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# ============================================================================
# Gateway Configuration
# ============================================================================
MAPTILER_API_KEY=your_maptiler_api_key_here

# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
A2A_API_KEY=your_a2a_bearer_token_here
